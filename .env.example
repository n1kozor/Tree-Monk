# FamilySearch integration. Copy to .env and fill in your Beta/Production AppKey.
# The AppKey (client_id) is a public PKCE client id — not a secret — but keep it
# out of git. Register the redirect URI with FamilySearch (devsupport@familysearch.org).
MAIN_VITE_FS_CLIENT_ID=
MAIN_VITE_FS_ENV=beta
MAIN_VITE_FS_REDIRECT_URI=http://127.0.0.1:4321/auth/callback
