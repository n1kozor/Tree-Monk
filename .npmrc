# Keep `npm install` output clean and reproducible.
#
# audit=false  — the remaining advisories are all in BUILD-ONLY tooling
#                (electron-builder → tar, vite → esbuild dev-server) plus the
#                bundled Electron, none of which can be bumped without major
#                breaking upgrades. We don't run the noisy audit on every
#                install; run `npm audit` manually when you want the report.
# fund=false   — suppress the "packages are looking for funding" notice.
audit=false
fund=false
