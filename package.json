{
  "name": "treemonk",
  "version": "1.5.3",
  "description": "TreeMonk - a local-first genealogy and historical research workbench",
  "type": "module",
  "main": "./out/main/index.js",
  "author": "TreeMonk (n1kozor)",
  "homepage": "https://treemonk.eu",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/n1kozor/Tree-Monk.git"
  },
  "bugs": {
    "url": "https://github.com/n1kozor/Tree-Monk/issues"
  },
  "license": "SEE LICENSE IN LICENSE",
  "scripts": {
    "dev": "electron-vite dev",
    "start": "electron-vite preview",
    "build": "electron-vite build",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:e2e": "electron-vite build && playwright test",
    "test:e2e:headed": "electron-vite build && playwright test --headed",
    "test:e2e:ui": "electron-vite build && playwright test --ui",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "postinstall": "electron-rebuild -f -w better-sqlite3",
    "dist:linux": "electron-vite build && electron-builder --linux",
    "dist:win": "electron-vite build && electron-builder --win",
    "dist:mac": "electron-vite build && electron-builder --mac"
  },
  "dependencies": {
    "@dagrejs/dagre": "^1.1.8",
    "@openhistoricalmap/map-styles": "^0.9.15",
    "@openhistoricalmap/maplibre-gl-dates": "^1.3.0",
    "@turf/along": "^7.3.5",
    "@turf/bezier-spline": "^7.3.5",
    "@turf/helpers": "^7.3.5",
    "@turf/length": "^7.3.5",
    "adm-zip": "^0.5.17",
    "archiver": "^7.0.1",
    "better-sqlite3": "^11.3.0",
    "d3-hierarchy": "^3.1.2",
    "d3-shape": "^3.2.0",
    "electron-updater": "^6.3.9",
    "framer-motion": "^11.18.2",
    "leaflet": "^1.9.4",
    "leaflet.markercluster": "^1.5.3",
    "maplibre-gl": "^4.7.1",
    "react-leaflet": "^4.2.1",
    "react-leaflet-cluster": "^2.1.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "@playwright/test": "^1.61.0",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-dropdown-menu": "^2.1.2",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-scroll-area": "^1.2.1",
    "@radix-ui/react-separator": "^1.1.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.1",
    "@radix-ui/react-tooltip": "^1.1.4",
    "@types/adm-zip": "^0.5.8",
    "@types/archiver": "^6.0.4",
    "@types/better-sqlite3": "^7.6.11",
    "@types/d3-hierarchy": "^3.1.7",
    "@types/d3-shape": "^3.1.8",
    "@types/leaflet": "^1.9.21",
    "@types/leaflet.markercluster": "^1.5.6",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/sql.js": "^1.4.11",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/ui": "^4.1.9",
    "@xyflow/react": "^12.3.5",
    "autoprefixer": "^10.4.20",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "electron": "^31.3.0",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "i18next": "^23.15.1",
    "jsdom": "^29.1.1",
    "lucide-react": "^0.451.0",
    "postcss": "^8.4.47",
    "react": "^18.3.1",
    "react-d3-tree": "^3.6.2",
    "react-dom": "^18.3.1",
    "react-i18next": "^15.0.2",
    "sonner": "^1.5.0",
    "sql.js": "^1.14.1",
    "tailwind-merge": "^2.5.4",
    "tailwindcss": "^3.4.13",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.5.4",
    "vite": "^5.4.8",
    "vitest": "^4.1.9",
    "zustand": "^5.0.0"
  },
  "overrides": {
    "camelcase": "^8.0.0"
  }
}
